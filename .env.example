# 心动投递 - 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值

# ============== Supabase 配置 ==============
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============== 安全配置 (必须) ==============
# JWT 签名密钥 - 必须设置为随机字符串（至少32字符）
# 可以使用: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-at-least-32-characters

# 刷新令牌密钥 - 如果与 JWT_SECRET 不同
JWT_REFRESH_SECRET=your-secure-refresh-secret-at-least-32-characters

# ============== 可选配置 ==============

# 允许的跨域来源（用于 Content-Security-Policy）
ALLOWED_ORIGIN=https://your-domain.com

# Rate Limiting 配置
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000  # 15分钟

# 登录失败锁定配置
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION_MS=900000  # 15分钟

# ============== 加密配置 ==============

# Bcrypt 轮数（默认值12）
# 更高的值更安全但更慢
BCRYPT_ROUNDS=12
