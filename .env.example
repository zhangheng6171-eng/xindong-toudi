# 心动投递 - 环境变量配置

# 数据库配置
DATABASE_URL="postgresql://user:password@localhost:5432/xindongtoudi"

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT密钥
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN="7d"

# 短信服务配置
SMS_ACCESS_KEY="your-sms-access-key"
SMS_SECRET_KEY="your-sms-secret-key"
SMS_SIGN_NAME="心动投递"
SMS_TEMPLATE_CODE="SMS_12345678"

# 微信配置
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"

# 存储配置 (OSS)
OSS_ACCESS_KEY_ID="your-oss-access-key-id"
OSS_ACCESS_KEY_SECRET="your-oss-access-key-secret"
OSS_BUCKET="xindongtoudi"
OSS_REGION="oss-cn-beijing"
OSS_ENDPOINT="https://oss-cn-beijing.aliyuncs.com"

# 推送配置
PUSH_APP_KEY="your-push-app-key"
PUSH_MASTER_SECRET="your-push-master-secret"

# AI服务配置 (可选，用于开放式问题分析)
AI_API_KEY="your-ai-api-key"
AI_API_URL="https://api.openai.com/v1"

# 应用配置
NEXT_PUBLIC_APP_URL="https://xindongtoudi.com"
NEXT_PUBLIC_APP_NAME="心动投递"

# 匹配配置
MATCH_WEEKLY_COUNT=3
MATCH_MIN_SCORE=60

# 定时任务配置
WEEKLY_MATCH_CRON="0 20 * * 0"  # 每周日晚上8点
