# ========================================
# 微信开放平台配置
# ========================================
# 请复制此文件为 .env.local 并填入真实配置

# 微信开放平台应用ID
# 注册地址: https://open.weixin.qq.com
WECHAT_APP_ID=your_wechat_app_id

# 微信开放平台应用密钥
WECHAT_APP_SECRET=your_wechat_app_secret

# 微信授权回调地址
# 必须在微信开放平台设置授权回调域
WECHAT_REDIRECT_URI=https://xindong-toudi.pages.dev/api/auth/wechat/callback

# JWT Secret（用于生成登录token，可与主应用共用或单独配置）
JWT_SECRET=your_jwt_secret_key_for_wechat_login
